{
  "name": "bisuteria-backend",
  "version": "1.0.0",
  "description": "Backend - Sistema de Gestión Bisutería",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.js",
    "build": "tsc && node -e \"require('fs').cpSync('db', 'dist/db', {recursive: true})\"",
    "start": "node dist/index.js",
    "prod": "npm run build && npm run start:prod",
    "start:prod": "set NODE_ENV=production&& node dist/index.js"
  },
